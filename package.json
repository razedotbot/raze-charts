{
  "name": "@raze/charts",
  "version": "0.3.0",
  "description": "Open, dependency-free Canvas-2D financial charting library — drop-in compatible with the TradingView Charting Library widget API.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/charting_library.cjs.js",
  "module": "dist/charting_library.esm.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/charting_library.esm.js",
      "require": "./dist/charting_library.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node build.mjs && node examples/smoke.mjs",
    "dev": "node build.mjs --watch",
    "sync": "node scripts/sync-to-app.mjs",
    "prepare": "node build.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razedotbot/raze-charts.git"
  },
  "homepage": "https://github.com/razedotbot/raze-charts#readme",
  "bugs": {
    "url": "https://github.com/razedotbot/raze-charts/issues"
  },
  "keywords": [
    "charts",
    "charting",
    "canvas",
    "candlestick",
    "financial",
    "trading",
    "ohlcv",
    "technical-indicators",
    "tradingview",
    "datafeed",
    "charting-library"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.0"
  }
}
